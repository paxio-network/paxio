{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "products/*/app/**/*.ts"],
  "exclude": ["node_modules", "tests", "dist", "apps/frontend", "opensrc"]
}
