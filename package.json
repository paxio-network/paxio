{
  "name": "paxio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Paxio — Agent Financial OS (product-first monorepo)",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "test": "vitest",
    "test:specs": "vitest run --config vitest.specs.config.ts",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "lint": "eslint . && prettier --check \"**/*.{js,cjs,ts,tsx,json,md}\"",
    "fix": "eslint . --fix && prettier --write \"**/*.{js,cjs,ts,tsx,json,md}\"",
    "build": "tsc -p tsconfig.app.json",
    "dev:server": "node --watch apps/back/server/main.cjs",
    "server": "node apps/back/server/main.cjs",
    "turbo:build": "turbo run build",
    "turbo:test": "turbo run test",
    "turbo:typecheck": "turbo run typecheck",
    "postinstall": "git submodule update --init --recursive 2>/dev/null || true"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.0.0",
    "metaskills": "^1.0.4",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.9.6",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
