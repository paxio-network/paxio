# Paxio production environment template.
#
# COPY this file to `.env.production` on the Hetzner host (NEVER commit the
# real .env.production — it lives only on the server). Values below are
# placeholders.
#
# DB_PASSWORD MUST also be written to ./secrets/db_password.txt (no newline)
# — Postgres uses POSTGRES_PASSWORD_FILE secret-mount, but DATABASE_URL
# below needs the literal password inline so backend/pg-client can connect.
# The two MUST match.

# App
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database — paxio-postgres is the docker-compose service name + Docker DNS
DB_PASSWORD=CHANGEME_RANDOM_32_CHARS
DATABASE_URL=postgres://paxio:CHANGEME_RANDOM_32_CHARS@postgres:5432/paxio

# CORS — production frontend origins (Vercel-deployed apps)
CORS_ORIGINS=https://paxio.network,https://registry.paxio.network,https://pay.paxio.network,https://radar.paxio.network,https://intel.paxio.network,https://docs.paxio.network,https://wallet.paxio.network,https://fleet.paxio.network

# ICP — local replica is dev-only, prod talks to the IC mainnet directly
# IC_HOST=https://ic0.app
# IC_NETWORK=ic

# Redis (optional — leave empty to skip from /health)
REDIS_URL=

# Qdrant (optional — leave empty to skip from /health)
QDRANT_URL=
