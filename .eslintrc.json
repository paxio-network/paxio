{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "target",
    "products/*/canister/target",
    "products/*/canisters/*/target",
    "platform/canister-shared/target",
    "apps/frontend/*/.next",
    "apps/frontend/*/.turbo",
    "opensrc",
    ".git"
  ]
}
