# Paxio — environment variables template.
# Copy to .env and fill in. NEVER commit .env (gitignored in .gitignore:15).
# Each variable is documented in docs/secrets.md (rotation, owner, scope).

# ───────────────────────────────────────────────────────────────
# Package publishing — CI/CD
# ───────────────────────────────────────────────────────────────

# PyPI — publish paxio-sdk (Python). https://pypi.org/manage/account/token/
# Scope: "paxio-sdk" project. Rotation: 180 days. Owner: user.
PYPI_TOKEN=

# npm — publish @paxio/* packages (TS SDK, MCP, proxy, cli, langchain, eliza).
# Generate at https://www.npmjs.com/settings/paxio/tokens — type: Automation.
# Scope: @paxio/*. Rotation: 180 days. Owner: user.
NPM_TOKEN=

# JSR — @paxio/* packages. NO TOKEN needed: uses OIDC via GitHub Actions
# (permissions: id-token: write + contents: read). Just ensure the scope
# @paxio exists on jsr.io and the GitHub repo is linked as publisher.

# crates.io — publish paxio-cli (Rust binary). https://crates.io/me
# Rotation: 365 days. Owner: user.
CARGO_TOKEN=

# ───────────────────────────────────────────────────────────────
# Deployment
# ───────────────────────────────────────────────────────────────

# Hetzner — Fastify backend (api.paxio.network). Mirror of complior/PROJECT.
# Owner: user. Set these values in GitHub repo Secrets for deploy-backend.yml.
HETZNER_HOST=
HETZNER_USER=
HETZNER_SSH_KEY=

# Vercel — frontend (8 Next.js apps). Personal account token.
# https://vercel.com/account/tokens — scope: Full Access (required for
# monorepo projects). Rotation: 180 days. Owner: user.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID_MARKETING=
VERCEL_PROJECT_ID_REGISTRY=
VERCEL_PROJECT_ID_PAY=
VERCEL_PROJECT_ID_RADAR=
VERCEL_PROJECT_ID_INTEL=
VERCEL_PROJECT_ID_DOCS=
VERCEL_PROJECT_ID_WALLET=
VERCEL_PROJECT_ID_FLEET=

# Docker Hub (optional — for CLI docker images).
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=

# ───────────────────────────────────────────────────────────────
# Runtime — Backend
# ───────────────────────────────────────────────────────────────

# PostgreSQL — agent metadata, registry state. dev local via docker-compose.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/paxio_dev

# Redis — session cache, rate limits, hot state.
REDIS_URL=redis://localhost:6379

# Qdrant — vector embeddings for Registry semantic search.
QDRANT_URL=http://localhost:6333

# ICP — canister IDs on mainnet (populated after first deploy).
ICP_NETWORK=local
ICP_IDENTITY_PEM=
REGISTRY_CANISTER_ID=
WALLET_CANISTER_ID=
SECURITY_SIDECAR_CANISTER_ID=
AUDIT_LOG_CANISTER_ID=

# ───────────────────────────────────────────────────────────────
# External services
# ───────────────────────────────────────────────────────────────

# Guard ML (external service by a3ka team — guard.paxio.network).
GUARD_API_URL=https://guard.paxio.network
GUARD_API_KEY=

# Privy — auth for frontend (wallet + email magic link). Per-app keys.
# Each frontend app gets its own Privy project:
NEXT_PUBLIC_PRIVY_APP_ID_MARKETING=
NEXT_PUBLIC_PRIVY_APP_ID_REGISTRY=
NEXT_PUBLIC_PRIVY_APP_ID_WALLET=
NEXT_PUBLIC_PRIVY_APP_ID_PAY=
NEXT_PUBLIC_PRIVY_APP_ID_INTEL=
NEXT_PUBLIC_PRIVY_APP_ID_FLEET=
