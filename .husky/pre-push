#!/usr/bin/env bash
# TD-dev-push — Mechanical push enforcement.
#
# Runs before every `git push`. Refuses pushes when:
#   1. git config user.email does not match a known role mapping
#   2. dev / test-runner identities push to refs/heads/dev or refs/heads/main
#      (devs can only push feature/* branches; only architect+user push dev/main)
#   3. force-push to dev or main is attempted by anyone (architect+user included)
#
# Reviewer narrow push to dev (docs/project-state.md + docs/tech-debt.md only)
# is allowed — scope is enforced at commit time by .husky/pre-commit, so any
# commit reviewer pushes is already scope-safe.
#
# Hook is the backstop for .claude/rules/scope-guard.md::GIT & MERGE rules.
# Bypass with --no-verify is forbidden by policy (see CLAUDE.md::Git Safety).

# Husky v9 dispatcher: re-exec under bash for set -euo pipefail.
if [ -z "${BASH_VERSION:-}" ]; then
  exec bash "$0" "$@"
fi

set -euo pipefail

EMAIL=$(git config user.email 2>/dev/null || echo "")

# ---------------------------------------------------------------------------
# Allowlist of known role identities
# ---------------------------------------------------------------------------

case "$EMAIL" in
  architect@paxio.network)        ROLE="architect" ;;
  reviewer@paxio.network)         ROLE="reviewer" ;;
  backend-dev@paxio.network)      ROLE="dev" ;;
  frontend-dev@paxio.network)     ROLE="dev" ;;
  icp-dev@paxio.network)          ROLE="dev" ;;
  registry-dev@paxio.network)     ROLE="dev" ;;
  test-runner@paxio.network)      ROLE="test-runner" ;;
  *)                              ROLE="user" ;;  # human user, GH bot, etc.
esac

# ---------------------------------------------------------------------------
# Read pre-push stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
# Iterate over each ref being pushed.
# ---------------------------------------------------------------------------

EXIT=0

while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  [ -z "${REMOTE_REF:-}" ] && continue

  # Strip refs/heads/ prefix
  BRANCH="${REMOTE_REF#refs/heads/}"

  # -----------------------------------------------------------------------
  # Rule 1: Force-push to protected branches forbidden for everyone except
  # explicit user override (architect mistakes are caught here).
  # -----------------------------------------------------------------------
  case "$BRANCH" in
    dev|main)
      # Force-push is detected by remote SHA exists but is not ancestor of
      # local SHA. Pre-push doesn't directly receive --force flag, so we
      # check ancestry: if REMOTE_SHA != 0 and is NOT ancestor of LOCAL_SHA
      # → force/non-fast-forward.
      ZERO="0000000000000000000000000000000000000000"
      if [ "$REMOTE_SHA" != "$ZERO" ]; then
        if ! git merge-base --is-ancestor "$REMOTE_SHA" "$LOCAL_SHA" 2>/dev/null; then
          echo "❌ pre-push REJECTED (force-push to $BRANCH forbidden, identity=$EMAIL)"
          echo "   $REMOTE_REF $REMOTE_SHA → $LOCAL_SHA is not fast-forward."
          echo "   Hard rule: no force-push to dev/main, ever."
          EXIT=1
          continue
        fi
      fi
      ;;
  esac

  # -----------------------------------------------------------------------
  # Rule 2: dev / test-runner identities CANNOT push dev or main.
  # They CAN push feature/* (and any non-protected branch).
  # -----------------------------------------------------------------------
  if [ "$ROLE" = "dev" ] || [ "$ROLE" = "test-runner" ]; then
    case "$BRANCH" in
      dev|main)
        echo "❌ pre-push REJECTED (identity=$EMAIL → $REMOTE_REF)"
        echo ""
        echo "   $ROLE identities cannot push to dev or main."
        echo "   Allowed: feature/* branches only."
        echo ""
        echo "   If you need to publish work, push to your feature/*."
        echo "   Architect handles dev/main merges via gh pr merge."
        echo ""
        echo "   Hard rule from .claude/rules/scope-guard.md::GIT & MERGE."
        EXIT=1
        continue
        ;;
    esac
  fi

  # -----------------------------------------------------------------------
  # Rule 3: Unknown identity warning (don't reject — architect emergency
  # ops sometimes happen under user identity).
  # -----------------------------------------------------------------------
  if [ "$ROLE" = "user" ] && [ -z "$EMAIL" ]; then
    echo "⚠️  pre-push: empty git user.email — set identity before push."
    echo "   Allowing (user override)."
  fi

done

if [ "$EXIT" -ne 0 ]; then
  echo ""
  echo "Bypass with --no-verify is policy-forbidden (CLAUDE.md::Git Safety)."
  exit 1
fi

echo "✅ pre-push OK (identity=$EMAIL role=$ROLE)"
