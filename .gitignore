# Node
node_modules/
dist/
coverage/
.vite/
.next/

# Rust
canisters/target/
canisters/.dfx/
target/
Cargo.lock.orig

# Env
.env
.env.*
!.env.example
!.env.production.example

# Build artifacts
*.log
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test output
test-results/
playwright-report/
vitest-test-*/

# Frontend (8 Next.js apps at apps/frontend/*)
apps/frontend/*/node_modules/
apps/frontend/*/.next/
apps/frontend/*/out/
apps/frontend/*/.turbo/

# Scratch / reference — NEVER commit
tmp/
scratch/
*.scratch
*.scratch.md

# Turborepo local cache
.turbo/

# pnpm
.pnpm-store/

# opensrc — pinned external clones (each dev fetches via opensrc/fetch.sh)
opensrc/repos/*
!opensrc/repos/.gitkeep

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock
.claude/*.lock
.claude/extensions/
.claude/worktrees/
.claude/wrappers/

# Pi (alt agent harness) runtime state
.pi/

# M-Q17: literal $HOME directory — defence against unexpanded TMPDIR var.
# .claude/settings.json must NOT set env.TMPDIR (use per-user ~/.claude/settings.json
# with absolute path instead). See tests/m-tmpdir-no-literal-home.test.ts.
$HOME/

# Next.js auto-generated type file (each app regenerates on dev)
apps/frontend/*/next-env.d.ts
/opensrc/repos
