{
  "name": "paxio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Paxio — Agent Financial OS",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "test": "vitest",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "lint": "eslint . && prettier --check \"**/*.{js,cjs,ts,tsx,json,md}\"",
    "fix": "eslint . --fix && prettier --write \"**/*.{js,cjs,ts,tsx,json,md}\"",
    "build": "tsc -p tsconfig.app.json",
    "dev:server": "node --watch server/main.cjs",
    "server": "node server/main.cjs"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "metaskills": "^1.0.4",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
