{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@paxio/types": ["packages/types/src/index.ts"],
      "@paxio/interfaces": ["packages/interfaces/src/index.ts"],
      "@paxio/errors": ["packages/errors/src/index.ts"],
      "@paxio/utils": ["packages/utils/src/index.ts"],
      "@paxio/utils/clock": ["packages/utils/src/clock.ts"],
      "@paxio/utils/logger": ["packages/utils/src/logger.ts"],
      "@paxio/api-client": ["packages/api-client/src/index.ts"],
      "@paxio/hooks": ["packages/hooks/src/index.ts"],
      "@paxio/ui": ["packages/ui/src/index.tsx"]
    },
    "types": ["node"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "products/*/app/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "target",
    "canisters/target",
    "apps/frontend",
    "products/*/canister",
    "products/*/canisters",
    "products/*/cli",
    "products/*/http-proxy",
    "products/*/ml",
    "products/04-security/guard",
    "opensrc"
  ]
}
